{
  "name": "opencode-mempalace",
  "version": "1.0.0",
  "description": "OpenCode plugin for MemPalace AI memory system - gives your AI permanent memory across sessions",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node && tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "mempalace",
    "memory",
    "ai",
    "persistence",
    "plugin",
    "llm",
    "context"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victornor/opencode-mempalace.git"
  },
  "bugs": {
    "url": "https://github.com/victornor/opencode-mempalace/issues"
  },
  "homepage": "https://github.com/victornor/opencode-mempalace#readme",
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
